-- Conformance: Option and Result Combinators (Chapter 9, Section 9.3.7)
-- Tests: option_unwrap_or, option_map, option_and_then, result_unwrap_or, result_map (types from prelude)
-- Also pins the #604 fix: prelude combinators work when the closure
-- arg is a `SlotRef` typed with an `FnType` alias (e.g. `@IntMap.0`),
-- not just AnonFn literals.  Pre-fix this produced wrong mono
-- suffixes (`option_map$Int_Bool`) and trapped at runtime.
type IntMap = fn(Int -> Int) effects(pure);

-- option_unwrap_or: Some returns inner value
public fn test_unwrap_some(@Unit -> @Int)
  requires(true)
  ensures(true)
  effects(pure)
{
  option_unwrap_or(Some(42), 0)
}

-- option_map: transforms value inside Some
public fn test_map_some(@Unit -> @Int)
  requires(true)
  ensures(true)
  effects(pure)
{
  option_unwrap_or(option_map(Some(10), fn(@Int -> @Int) effects(pure) { @Int.0 + 1 }), 0)
}

-- option_and_then: chains fallible operations
public fn test_and_then_some(@Unit -> @Int)
  requires(true)
  ensures(true)
  effects(pure)
{
  option_unwrap_or(option_and_then(Some(5), fn(@Int -> @Option<Int>) effects(pure) { Some(@Int.0 * 2) }), 0)
}

-- result_unwrap_or: Ok returns inner value
public fn test_result_ok(@Unit -> @Int)
  requires(true)
  ensures(true)
  effects(pure)
{
  result_unwrap_or(Ok(77), 0)
}

-- result_map: transforms Ok value
public fn test_result_map(@Unit -> @Int)
  requires(true)
  ensures(true)
  effects(pure)
{
  result_unwrap_or(result_map(Ok(100), fn(@Int -> @Int) effects(pure) { @Int.0 - 1 }), 0)
}

-- option_map called via SlotRef-typed-as-FnType-alias closure (#604).
-- Helper takes the closure via `@IntMap` and applies the prelude
-- combinator.  Pre-#604-fix the mono suffix was wrong (Int_Bool)
-- and this trapped at runtime; post-fix the suffix is Int_Int and
-- the call returns the mapped value.
private fn map_with_slot_closure(@Option<Int>, @IntMap -> @Option<Int>)
  requires(true)
  ensures(true)
  effects(pure)
{
  option_map(@Option<Int>.0, @IntMap.0)
}

public fn test_map_some_via_slot(@Unit -> @Int)
  requires(true)
  ensures(true)
  effects(pure)
{
  option_unwrap_or(map_with_slot_closure(Some(7), fn(@Int -> @Int) effects(pure) { @Int.0 * 3 }), 0)
}

-- Integration: all combinators compose
public fn main(@Unit -> @Int)
  requires(true)
  ensures(true)
  effects(pure)
{
  test_unwrap_some(()) + test_map_some(()) + test_and_then_some(()) + test_result_ok(()) + test_result_map(()) + test_map_some_via_slot(())
}
