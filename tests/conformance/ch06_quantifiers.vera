-- Conformance: quantifiers in contracts (Chapter 6)
-- Tests: forall and exists over arrays
private fn all_positive(@Array<Int> -> @Bool)
  requires(true)
  ensures(true)
  effects(pure)
{
  forall(@Int, array_length(@Array<Int>.0), fn(@Int -> @Bool) effects(pure) { @Array<Int>.0[@Int.0] > 0 })
}

private fn has_zero(@Array<Int> -> @Bool)
  requires(true)
  ensures(true)
  effects(pure)
{
  exists(@Int, array_length(@Array<Int>.0), fn(@Int -> @Bool) effects(pure) { @Array<Int>.0[@Int.0] == 0 })
}

public fn main(@Unit -> @Bool)
  requires(true)
  ensures(true)
  effects(pure)
{
  -- ensures(true): `all_positive`'s postcondition is `ensures(true)`,
  -- so the static verifier can't conclude `@Bool.result == true`
  -- from the specific input [1, 2, 3].  Pre-#667 the ArrayLit
  -- returned None from `smt.translate_expr`, so the body
  -- translation failed and the verifier dropped this
  -- postcondition to Tier 3 with an E522 warning ("Cannot
  -- statically verify postcondition…").  Post-#667 the body
  -- translates fully, the verifier reaches the contradiction,
  -- and reports E500 — the contract has been honestly relaxed.
  all_positive([1, 2, 3])
}

public fn test_has_zero(@Unit -> @Bool)
  requires(true)
  ensures(true)
  effects(pure)
{
  -- Same rationale as `main` above: `has_zero`'s `ensures(true)`
  -- doesn't propagate enough info for the static verifier.
  has_zero([1, 0, 3])
}
