-- Conformance: Non-commutative slot indexing (Chapter 3)
-- Tests: subtraction, division, comparison with correct De Bruijn ordering
-- subtract_first_from_second: computes second_param - first_param
-- @Int.1 = first param (leftmost), @Int.0 = second param (rightmost/most-recent)
-- Body and ensures both use @Int.0 - @Int.1 (second minus first)
private fn subtract_first_from_second(@Int, @Int -> @Int)
  requires(true)
  ensures(@Int.result == @Int.0 - @Int.1)
  effects(pure)
{
  @Int.0 - @Int.1
}

-- divide_larger_by_smaller: computes first_param / second_param
-- @Int.1 = first param (larger, dividend), @Int.0 = second param (smaller, divisor)
private fn divide_larger_by_smaller(@Int, @Int -> @Int)
  requires(@Int.0 != 0 && @Int.1 != 0)
  ensures(@Int.result == @Int.1 / @Int.0)
  effects(pure)
{
  @Int.1 / @Int.0
}

-- is_second_less_than_first: returns true when second_param < first_param
-- @Int.0 = second param (most-recent), @Int.1 = first param (older)
private fn is_second_less_than_first(@Int, @Int -> @Bool)
  requires(true)
  ensures(@Bool.result == @Int.0 < @Int.1)
  effects(pure)
{
  @Int.0 < @Int.1
}

-- main: exercise all three functions with concrete values that give result 0
public fn main(@Unit -> @Int)
  requires(true)
  ensures(@Int.result == 0)
  effects(pure)
{
  -- subtract_first_from_second(5, 5) => 5 - 5 = 0
  subtract_first_from_second(5, 5)
}
