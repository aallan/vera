-- Conformance: string search and transformation builtins (Chapter 9)
-- Tests: string_contains, string_starts_with, string_ends_with, string_index_of,
--        string_upper, string_lower, string_replace, string_split, string_join
public fn test_string_contains(@Unit -> @Bool)
  requires(true)
  ensures(@Bool.result == true)
  effects(pure)
{
  string_contains("hello world", "world")
}

public fn test_starts_with(@Unit -> @Bool)
  requires(true)
  ensures(@Bool.result == true)
  effects(pure)
{
  string_starts_with("hello world", "hello")
}

public fn test_ends_with(@Unit -> @Bool)
  requires(true)
  ensures(@Bool.result == true)
  effects(pure)
{
  string_ends_with("hello world", "world")
}

public fn test_index_of(@Unit -> @Int)
  requires(true)
  ensures(@Int.result == 6)
  effects(pure)
{
  match string_index_of("hello world", "world") {
    Some(@Nat) -> nat_to_int(@Nat.0),
    None -> 0 - 1
  }
}

public fn test_to_upper(@Unit -> @String)
  requires(true)
  ensures(true)
  effects(pure)
{
  string_upper("hello")
}

public fn test_to_lower(@Unit -> @String)
  requires(true)
  ensures(true)
  effects(pure)
{
  string_lower("HELLO")
}

public fn test_replace(@Unit -> @String)
  requires(true)
  ensures(true)
  effects(pure)
{
  string_replace("hello world", "world", "vera")
}

public fn test_split_join(@Unit -> @String)
  requires(true)
  ensures(true)
  effects(pure)
{
  string_join(string_split("a,b,c", ","), "-")
}

public fn main(@Unit -> @Int)
  requires(true)
  ensures(true)
  effects(pure)
{
  if string_contains("vera", "er") then {
    1
  } else {
    0
  }
}
