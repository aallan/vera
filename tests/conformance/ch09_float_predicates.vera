-- Conformance: Float64 special value operations (Chapter 9)
-- Tests: float_is_nan, float_is_infinite, nan, infinity
public fn test_nan_constant(@Unit -> @Float64)
  requires(true)
  ensures(true)
  effects(pure)
{
  nan()
}

public fn test_infinity_constant(@Unit -> @Float64)
  requires(true)
  ensures(true)
  effects(pure)
{
  infinity()
}

public fn test_is_nan_true(@Unit -> @Int)
  requires(true)
  ensures(@Int.result == 1)
  effects(pure)
{
  if float_is_nan(nan()) then {
    1
  } else {
    0
  }
}

public fn test_is_nan_false(@Unit -> @Int)
  requires(true)
  ensures(@Int.result == 0)
  effects(pure)
{
  if float_is_nan(1.5) then {
    1
  } else {
    0
  }
}

public fn test_is_nan_infinity(@Unit -> @Int)
  requires(true)
  ensures(@Int.result == 0)
  effects(pure)
{
  if float_is_nan(infinity()) then {
    1
  } else {
    0
  }
}

public fn test_is_infinite_true(@Unit -> @Int)
  requires(true)
  ensures(@Int.result == 1)
  effects(pure)
{
  if float_is_infinite(infinity()) then {
    1
  } else {
    0
  }
}

public fn test_is_infinite_negative(@Unit -> @Int)
  requires(true)
  ensures(@Int.result == 1)
  effects(pure)
{
  if float_is_infinite(0.0 - infinity()) then {
    1
  } else {
    0
  }
}

public fn test_is_infinite_false(@Unit -> @Int)
  requires(true)
  ensures(@Int.result == 0)
  effects(pure)
{
  if float_is_infinite(2.5) then {
    1
  } else {
    0
  }
}

public fn test_is_infinite_nan(@Unit -> @Int)
  requires(true)
  ensures(@Int.result == 0)
  effects(pure)
{
  if float_is_infinite(nan()) then {
    1
  } else {
    0
  }
}

public fn main(@Unit -> @Int)
  requires(true)
  ensures(@Int.result == 1)
  effects(pure)
{
  if float_is_nan(nan()) then {
    1
  } else {
    0
  }
}
