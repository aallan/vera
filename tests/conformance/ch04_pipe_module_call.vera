import vera.math(magnitude);

public fn main(@Unit -> @Int)
  requires(true)
  ensures(@Int.result >= 0)
  effects(pure)
{
  -5 |> vera.math::magnitude()
}

public fn test_chained(@Unit -> @Int)
  requires(true)
  ensures(@Int.result >= 0)
  effects(pure)
{
  -5 |> vera.math::magnitude() |> vera.math::magnitude()
}
