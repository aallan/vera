			"end": "-\\}",
			"patterns": [
				{
					"include": "#block_comment"
				}
			]
		},
		{
			"name": "string.quoted.double.vera",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "meta.interpolation.vera",
					"begin": "\\\\\\(",
					"beginCaptures": {
						"0": {
							"name": "punctuation.section.interpolation.begin.vera"
						}
					},
					"end": "\\)",
					"endCaptures": {
						"0": {
							"name": "punctuation.section.interpolation.end.vera"
						}
					},
					"contentName": "source.vera.embedded",
					"patterns": [
						{
							"include": "$self"
						}
					]
				},
				{
					"name": "constant.character.escape.vera",
					"match": "\\\\[nrt\\\\\"0]"
				}
			]
		},
		{
			"name": "variable.other.slot.vera",
			"match": "@[A-Z][A-Za-z0-9_]*(?:<[^>]*>)*\\.(?:result|\\d+)"
		},
		{
			"name": "variable.other.slot-binding.vera",
			"match": "@[A-Z][A-Za-z0-9_]*(?:<[^>]*>)*(?=\\s*[,)\\]}])"
		},
		{
			"name": "constant.numeric.float.vera",
			"match": "\\b\\d+\\.\\d+(?:[eE][+-]?\\d+)?\\b"
		},
		{
			"name": "constant.numeric.integer.vera",
			"match": "\\b\\d+\\b"
		},
