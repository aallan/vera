-- Factorial: demonstrates recursion with a decreases clause.
public fn factorial(@Nat -> @Nat)
  requires(true)
  ensures(@Nat.result >= 1)
  decreases(@Nat.0)
  effects(pure)
{
  if @Nat.0 == 0 then {
    1
  } else {
    @Nat.0 * factorial(@Nat.0 - 1)
  }
}

-- Entry point: exercise factorial(5) = 120
public fn test_factorial(@Unit -> @Nat)
  requires(true)
  ensures(true)
  effects(pure)
{
  factorial(5)
}
