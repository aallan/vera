-- Absolute value: a simple pure function with postconditions.
public fn absolute_value(@Int -> @Nat)
  requires(true)
  ensures(@Nat.result >= 0)
  ensures(@Nat.result == @Int.0 || @Nat.result == -@Int.0)
  effects(pure)
{
  if @Int.0 >= 0 then {
    @Int.0
  } else {
    -@Int.0
  }
}

-- Entry point: exercise absolute_value with a negative input
public fn test_abs(@Unit -> @Nat)
  requires(true)
  ensures(true)
  effects(pure)
{
  absolute_value(-42)
}
